<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Society Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<!--
  The theme is applied as a class on <body>. We read the saved choice
  from localStorage BEFORE the page paints, so there's no "flash" of
  the wrong theme on reload. See public/js/theme.js for the toggle logic.
-->
<body class="light-mode">
<script>
  // Runs immediately, before the rest of the page loads
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'dark') {
    document.body.classList.remove('light-mode');
    document.body.classList.add('dark-mode');
  }
</script>
