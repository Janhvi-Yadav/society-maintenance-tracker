<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="login-page">
  <div class="login-card">
    <div class="login-top">
      <h1>Welcome back</h1>
      <p>Sign in to your account</p>
    </div>

    <%- include('../partials/flash') %>

    <form action="/auth/login" method="POST" id="loginForm">
      <label for="email">EMAIL ADDRESS</label>
      <input type="email" id="email" name="email" placeholder="you@example.com" required>

      <label for="password">PASSWORD</label>
      <input type="password" id="password" name="password" placeholder="••••••••" required>

      <button type="submit" class="btn btn-login">Sign In</button>
    </form>

    <p class="form-footer-text">Don't have an account? <a href="/auth/register">Register</a></p>

    <!-- Demo accounts — clicking fills the form automatically -->
    <div class="demo-accounts">
      <p class="demo-title">DEMO ACCOUNTS</p>
      <button type="button" class="demo-btn" onclick="fillDemo('admin@society.com', 'admin123')">
        Admin: admin@society.com
      </button>
      <button type="button" class="demo-btn" onclick="fillDemo('resident1@society.com', 'resident123')">
        Resident 1: resident1@society.com
      </button>
      <button type="button" class="demo-btn" onclick="fillDemo('resident2@society.com', 'resident123')">
        Resident 2: resident2@society.com
      </button>
    </div>
  </div>
</div>

<script>
  function fillDemo(email, password) {
    document.getElementById('email').value = email;
    document.getElementById('password').value = password;
    // Don't submit — user clicks Sign In button themselves
  }
</script>

<%- include('../partials/footer') %>
