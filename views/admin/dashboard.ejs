<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
  <h1>Dashboard</h1>
  <%- include('../partials/flash') %>

  <div class="stats-grid">
    <div class="card stat-card">
      <h2><%= totalCount %></h2>
      <p>Total Complaints</p>
    </div>
    <div class="card stat-card stat-overdue">
      <h2><%= overdueCount %></h2>
      <p>Overdue</p>
    </div>
  </div>

  <div class="stats-row">
    <div class="card stat-block">
      <h3>By Status</h3>
      <% byStatus.forEach(s => { %>
        <div class="stat-line">
          <span class="badge badge-<%= s._id.replace(' ', '').toLowerCase() %>"><%= s._id %></span>
          <span class="stat-count"><%= s.count %></span>
        </div>
      <% }) %>
    </div>

    <div class="card stat-block">
      <h3>By Category</h3>
      <% byCategory.forEach(c => { %>
        <div class="stat-line">
          <span><%= c._id %></span>
          <span class="stat-count"><%= c.count %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <a href="/admin/complaints" class="btn btn-primary">View All Complaints</a>

  <!-- Latest Notices Section -->
  <div class="dashboard-notices">
    <div class="page-header" style="margin-top: 32px;">
      <h2>Latest Notices</h2>
      <a href="/admin/notices/new" class="btn btn-primary">+ Post Notice</a>
    </div>

    <% if (latestNotices.length === 0) { %>
      <p class="empty-state">No notices yet. <a href="/admin/notices/new">Post one</a></p>
    <% } else { %>
      <div class="notice-list">
        <% latestNotices.forEach(n => { %>
          <div class="card notice-card <%= n.isImportant ? 'notice-pinned' : '' %>">
            <% if (n.isImportant) { %><span class="badge badge-overdue">📌 Important</span><% } %>
            <h3><%= n.title %></h3>
            <p><%= n.content %></p>
            <p class="card-meta">By <%= n.postedBy.name %> on <%= n.createdAt.toDateString() %></p>
          </div>
        <% }) %>
      </div>
      <a href="/admin/notices" class="btn btn-secondary" style="margin-top: 12px;">View All Notices</a>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
