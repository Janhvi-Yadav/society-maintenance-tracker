<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
  <h1>Notice Board</h1>
  <%- include('../partials/flash') %>

  <div class="card form-card">
    <h2>Post a Notice</h2>
    <form action="/admin/notices" method="POST">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required>

      <label for="content">Content</label>
      <textarea id="content" name="content" rows="4" required></textarea>

      <label class="checkbox-label">
        <input type="checkbox" name="isImportant">
        Mark as important (pins to top + emails all residents)
      </label>

      <button type="submit" class="btn btn-primary">Post Notice</button>
    </form>
  </div>

  <h2 class="section-title">All Notices</h2>
  <div class="notice-list">
    <% notices.forEach(n => { %>
      <div class="card notice-card <%= n.isImportant ? 'notice-pinned' : '' %>">
        <% if (n.isImportant) { %><span class="badge badge-overdue">📌 Important</span><% } %>
        <h3><%= n.title %></h3>
        <p><%= n.content %></p>
        <p class="card-meta">By <%= n.postedBy.name %> on <%= n.createdAt.toDateString() %></p>
      </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
